# ═══════════════════════════════════════════════════════════════
# Giscus yorum sistemi yapılandırması
# Adımlar:
# 1. GitHub reposunda Settings > Features > Discussions'ı aç
# 2. github.com/apps/giscus adresinde repoyu yetkilendir
# 3. giscus.app adresine gidip repo bilgilerini gir, aşağıdaki değerleri al
# ═══════════════════════════════════════════════════════════════

NEXT_PUBLIC_GISCUS_REPO=ahmetakyapi/ahmetakyapi.com
NEXT_PUBLIC_GISCUS_REPO_ID=           # giscus.app'ten alınacak
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=       # giscus.app'ten alınacak

# ═══════════════════════════════════════════════════════════════
# Admin panel
# Production'da zorunlu — dev'de varsayılan değerler kullanılır
# ═══════════════════════════════════════════════════════════════

ADMIN_PASSWORD=                       # Production'da güçlü şifre belirle
ADMIN_SESSION_SECRET=                 # Rastgele uzun string (openssl rand -hex 32)

# ═══════════════════════════════════════════════════════════════
# GitHub API (opsiyonel — admin dashboard yorum istatistikleri)
# ═══════════════════════════════════════════════════════════════

GITHUB_TOKEN=                         # GitHub Personal Access Token (read:discussion)
